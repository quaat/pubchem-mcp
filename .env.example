# PubChem MCP server configuration
# All variables are optional; defaults are safe.

# Per-second request cap (hard maximum 5; PubChem documents 5 req/sec)
PUBCHEM_RPS=4

# Per-minute request cap (hard maximum 400)
PUBCHEM_RPM=240

# Per-request timeout in milliseconds
PUBCHEM_TIMEOUT_MS=30000

# Maximum retry attempts for transient failures (5xx, 429, network)
PUBCHEM_MAX_RETRIES=4

# In-memory cache TTL in milliseconds (default: 24 hours)
PUBCHEM_CACHE_TTL_MS=86400000

# Set to "1" to disable in-memory caching
# PUBCHEM_CACHE_DISABLE=1

# Maximum cache entries (LRU-style eviction)
PUBCHEM_CACHE_MAX_ENTRIES=1000

# Override PUG-REST base URL (advanced)
# PUBCHEM_BASE_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug

# Override PUG-View base URL (advanced)
# PUBCHEM_VIEW_BASE_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug_view

# Contact URL appended to User-Agent (recommended for production deployments)
# PUBCHEM_CONTACT_URL=https://example.com/contact

# Logger level: trace|debug|info|warn|error|fatal
PUBCHEM_LOG_LEVEL=info

# Set to "1" to run live integration tests (network calls to PubChem)
# PUBCHEM_MCP_LIVE_TESTS=1
